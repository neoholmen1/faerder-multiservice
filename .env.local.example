# Supabase — fyll inn etter at du har opprettet prosjektet (se SUPABASE_SETUP.md)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site-slug — bestemmer hvilken rad i `sites`-tabellen denne deployen tilhører
NEXT_PUBLIC_SITE_SLUG=faerder

# E-post (Resend) — krever konto på resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFICATION_EMAIL=post@faerdermultiservice.no

# Rate limiting (Upstash Redis) — valgfritt
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Analytics — valgfritt
NEXT_PUBLIC_GA_ID=
